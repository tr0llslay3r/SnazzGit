{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "snazzgit",
  "version": "0.1.0",
  "identifier": "com.snazzgit.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SnazzGit",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "A snazzy cross-platform Git GUI client",
    "longDescription": "SnazzGit is a cross-platform Git GUI client built with Tauri, featuring commit graph visualization, syntax-highlighted diffs, and a customizable theme system.",
    "category": "Development",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libglib2.0-0"
        ],
        "section": "devel",
        "priority": "optional"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "glib2"
        ]
      }
    }
  }
}
